# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role — SOLO server-side, nunca con prefijo NEXT_PUBLIC_. Se usa
# para invitar usuarios desde /admin/solicitudes (Supabase → Project
# Settings → API → service_role key). Si falta, el enrolamiento no podrá
# crear cuentas nuevas, pero el resto de la app sigue funcionando igual.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Email de enrolamiento (SMTP de la empresa) ─────────────────
# Notifica al Administrador de software cuando alguien pide acceso en
# /solicitar-acceso, y Supabase usa su propio sistema para la invitación
# final. Sin estas variables, las solicitudes se siguen guardando pero
# el correo de aviso no se envía (revisa los logs del servidor).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@2celectricidad.com
SMTP_PASS=contraseña-de-aplicación
# A quién le llega el aviso de cada solicitud nueva.
ADMIN_SOFTWARE_EMAIL=admin@2celectricidad.com
# URL pública del sitio, para armar links absolutos dentro de los correos.
NEXT_PUBLIC_SITE_URL=https://2c-inventario.vercel.app

# ── Clasificador IA (opcional) ─────────────────────────────────
# Activar con true para mostrar el botón "Clasificar con IA" en el importador.
# Key en: https://console.x.ai
AI_CLASSIFY_ENABLED=true
XAI_API_KEY=xai-...
NEXT_PUBLIC_AI_CLASSIFY_ENABLED=true
